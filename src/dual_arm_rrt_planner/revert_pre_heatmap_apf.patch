-bool LocalTRRT::normalizeVector(std::vector<double>& values)
-{
-  const double norm = computeVectorNorm(values);
-  if (!(norm > std::numeric_limits<double>::epsilon()))
-  {
-    return false;
-  }
-
-  for (double& value : values)
-  {
-    value /= norm;
-  }
-  return true;
-}
