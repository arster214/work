-double LocalTRRT::computeVectorNorm(const std::vector<double>& values)
-{
-  double squared_norm = 0.0;
-  for (double value : values)
-  {
-    squared_norm += value * value;
-  }
-  return std::sqrt(squared_norm);
-}
