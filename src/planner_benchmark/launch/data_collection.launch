<launch>
  <!-- 论文数据采集 Launch 文件 -->
  
  <!-- 参数 -->
  <arg name="config_file" default="$(find planner_benchmark)/config/test_poses.yaml" />
  <arg name="planner" default="" />
  <arg name="num_runs" default="50" />
  <arg name="timeout" default="30.0" />
  <arg name="planning_attempts" default="1" />
  <arg name="output_dir" default="$(env HOME)/benchmark_results" />
  <arg name="planning_watchdog_padding" default="15.0" />
  <arg name="worker_poll_interval" default="0.2" />
  <arg name="kill_move_group_on_timeout" default="true" />
  <arg name="move_group_node_name" default="/move_group" />
  <arg name="move_group_action_name" default="move_group" />
  <arg name="move_group_recovery_wait" default="15.0" />
  <arg name="move_group_shutdown_wait" default="5.0" />
  <arg name="move_group_ready_wait" default="15.0" />
  <arg name="reconnect_retry_delay" default="2.0" />
  <arg name="max_recovery_attempts" default="1" />
  <arg name="restart_move_group_command" default="" />
  <arg name="stop_on_unrecoverable_move_group" default="true" />
  
  <!-- 运行数据采集脚本 -->
  <node name="paper_data_collector" pkg="planner_benchmark" type="paper_data_collection.py" 
        output="screen" required="true">
    <param name="config_file" value="$(arg config_file)" />
    <param name="planner" value="$(arg planner)" />
    <param name="num_runs" value="$(arg num_runs)" />
    <param name="timeout" value="$(arg timeout)" />
    <param name="planning_attempts" value="$(arg planning_attempts)" />
    <param name="output_dir" value="$(arg output_dir)" />
    <param name="planning_watchdog_padding" value="$(arg planning_watchdog_padding)" />
    <param name="worker_poll_interval" value="$(arg worker_poll_interval)" />
    <param name="kill_move_group_on_timeout" value="$(arg kill_move_group_on_timeout)" />
    <param name="move_group_node_name" value="$(arg move_group_node_name)" />
    <param name="move_group_action_name" value="$(arg move_group_action_name)" />
    <param name="move_group_recovery_wait" value="$(arg move_group_recovery_wait)" />
    <param name="move_group_shutdown_wait" value="$(arg move_group_shutdown_wait)" />
    <param name="move_group_ready_wait" value="$(arg move_group_ready_wait)" />
    <param name="reconnect_retry_delay" value="$(arg reconnect_retry_delay)" />
    <param name="max_recovery_attempts" value="$(arg max_recovery_attempts)" />
    <param name="restart_move_group_command" value="$(arg restart_move_group_command)" />
    <param name="stop_on_unrecoverable_move_group" value="$(arg stop_on_unrecoverable_move_group)" />
  </node>
  
</launch>
