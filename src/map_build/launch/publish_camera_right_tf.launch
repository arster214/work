<launch>
    <arg name="parent_frame" default="r_link7" doc="父坐标系 ID (例如 base_link 或 tool0)"/>
    <arg name="child_frame" default="camera_link" doc="相机坐标系 ID"/>

    <node pkg="tf" type="static_transform_publisher" name="camera_tf_broadcaster"
        args="-0.08572244 0.03893551 0.00760923 0.01432994 -0.00372411 -0.70252555 0.71150449 $(arg parent_frame) $(arg child_frame) 100" />

</launch>
