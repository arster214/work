log4j.logger.ros=INFO

# Silence MoveIt state-completeness spam from the planning scene monitor while
# keeping other planner warnings visible.
log4j.logger.ros.planning_scene_monitor=ERROR
log4j.logger.ros.current_state_monitor=ERROR
log4j.logger.ros.moveit_ros_planning.planning_scene_monitor=ERROR
log4j.logger.ros.moveit_ros_planning.current_state_monitor=ERROR
